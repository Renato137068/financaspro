{
  "env": {
    "browser": true,
    "es6": true,
    "jest": true,
    "node": true
  },
  "globals": {
    "CONFIG": "readonly",
    "CATEGORIAS": "readonly",
    "DADOS": "readonly",
    "UTILS": "readonly",
    "TRANSACOES": "readonly",
    "ORCAMENTO": "readonly",
    "RENDER": "readonly",
    "CONFIG_USER": "readonly",
    "CONTAS": "readonly",
    "PIN_SECURITY": "readonly",
    "hashPin": "readonly",
    "SHORTCUTS": "readonly",
    "fpAlert": "readonly",
    "fpConfirm": "readonly",
    "fpPrompt": "readonly",
    "fecharModal": "readonly",
    "mudarAba": "readonly",
    "selecionarTipo": "readonly",
    "filtrarExtrato": "readonly",
    "exportarDados": "readonly",
    "exportarPDF": "readonly",
    "exportarExtrato": "readonly",
    "DOMUTILS": "readonly",
    "APRENDIZADO": "readonly",
    "AUTOMACAO": "readonly",
    "INSIGHTS": "readonly",
    "SCORE": "readonly",
    "CATEGORIZADOR": "readonly",
    "PIPELINE": "readonly",
    "PARSER": "readonly",
    "VALIDATIONS": "readonly",
    "XLSX": "readonly",
    "renderConfigTab": "readonly",
    "atualizarTipoIndicator": "readonly",
    "atualizarBadgeConfianca": "readonly",
    "verificarArmazenamento": "readonly",
    "verificarBackupAutomatico": "readonly",
    "verificarPinAoAbrir": "readonly",
    "tentarDesbloquear": "readonly",
    "togglePinSeguranca": "readonly",
    "toggleAlertaOrcamento": "readonly",
    "toggleLembreteDiario": "readonly",
    "setupPinInputs": "readonly",
    "setupNavigation": "readonly",
    "setupActionBindings": "readonly",
    "setupFormNovo": "readonly",
    "setupImport": "readonly",
    "setupInsightActions": "readonly",
    "setupAutoCategoria": "readonly",
    "APP_BOOTSTRAP": "readonly",
    "module": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "args": "none" }],
    "no-undef": "error",
    "eqeqeq": ["error", "smart"],
    "no-var": "off",
    "semi": ["error", "always"],
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-with": "error",
    "no-unused-expressions": "warn",
    "no-unreachable": "error",
    "no-self-compare": "error",
    "no-return-assign": "error",
    "no-throw-literal": "error",
    "no-multi-spaces": "warn",
    "no-constant-condition": ["error", { "checkLoops": false }]
  },
  "parserOptions": {
    "ecmaVersion": 2021
  }
}
