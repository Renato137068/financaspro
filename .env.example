# FinançasPro — variáveis de ambiente
# Copie para .env e preencha os valores reais

# ─── Ambiente ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── PostgreSQL (Prisma) ─────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://financaspro:changeme@localhost:5432/financaspro?schema=public"

# Para Docker Compose, use o nome do serviço como host:
# DATABASE_URL="postgresql://financaspro:changeme@postgres:5432/financaspro?schema=public"

# ─── Redis (Fase 10 — BullMQ + Cache) ─────────────────────────
# Deixe em branco em dev para desativar Redis (app funciona sem ele)
REDIS_URL=redis://localhost:6379
# Com senha: redis://:sua-senha@localhost:6379
# Para Docker: REDIS_URL=redis://:redispass@redis:6379

# ─── JWT ─────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-this-access-secret-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────
# Em produção, defina a origem exata (sem wildcard) para cookies HttpOnly funcionarem
CORS_ORIGIN=http://localhost:3000

# ─── Cookies de sessão ───────────────────────────────────────
# Lax | Strict | None (None exige Secure em produção)
COOKIE_SAME_SITE=Lax

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
RATE_LIMIT_AUTH_MAX=10

# ─── Logging ─────────────────────────────────────────────────
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ─── Segurança ───────────────────────────────────────────────
# PBKDF2: mínimo recomendado OWASP (2023) é 600000 para SHA-256.
PBKDF2_ITERATIONS=600000

# ─── URL pública do app (usada em e-mails e portal Stripe) ───
APP_URL=http://localhost:4000
# Origem extra no CSP do PWA no build (npm run build). Ex.: https://api.financaspro.com.br
# PUBLIC_API_URL=https://api.financaspro.com.br

# ─── Stripe (Fase 10 — Billing) ──────────────────────────────
# Obtenha em https://dashboard.stripe.com/apikeys
# Deixe em branco para operar sem Stripe (modo FREE apenas)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook: configure no Stripe Dashboard apontando para /api/v1/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs do Stripe Dashboard (Products → Prices)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_YEARLY=price_...

# ─── Open Finance (Fase 11 — Belvo / Pluggy) ─────────────────
# sandbox = modo demo (padrão). belvo/pluggy exigem credenciais abaixo.
OPEN_FINANCE_PROVIDER=sandbox
BELVO_ENV=sandbox
BELVO_SECRET_ID=
BELVO_SECRET_PASSWORD=
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=

# ─── Métricas e criptografia ─────────────────────────────────
# METRICS_TOKEN: enviado apenas via header X-Metrics-Token (não em ?token=).
METRICS_TOKEN=change-me-metrics-token
# TOTP_ENCRYPTION_KEY: OBRIGATÓRIA em produção se 2FA/TOTP for usado —
# sem ela, a gravação do segredo TOTP falha (fail-closed, nunca em texto claro).
TOTP_ENCRYPTION_KEY=
# Exige Redis em produção para rate limit distribuído (opcional)
REQUIRE_REDIS=0

# ─── E-mail SMTP (Fase 10 — Notificações) ─────────────────────
# Deixe em branco para simular envios no log (modo dev)
SMTP_HOST=smtp.seuprovedor.com.br
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu@email.com
SMTP_PASS=sua-senha-smtp
SMTP_FROM=FinançasPro <noreply@financaspro.com.br>

# ─── Docker Compose ───────────────────────────────────────────
DB_PASSWORD=changeme
REDIS_PASSWORD=redispass
