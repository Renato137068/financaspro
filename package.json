{
  "name": "financaspro-v11",
  "version": "11.0.0",
  "description": "FinançasPro — SaaS de Finanças Pessoais",
  "type": "module",
  "main": "index.html",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci && node scripts/backend-smoke-test.mjs && node scripts/backend-api-test.mjs && node scripts/backend-integration-test.mjs && node scripts/check-xss-sinks.cjs && node scripts/sync-conflict-test.mjs",
    "test:backend": "node scripts/backend-smoke-test.mjs",
    "test:api": "node scripts/backend-api-test.mjs",
    "test:unit": "jest --testPathPattern=tests/ --verbose",
    "test:open-coverage": "jest --coverage && start coverage/lcov-report/index.html",
    "lint": "eslint js/ backend/ --ext .js",
    "security:xss": "node scripts/check-xss-sinks.cjs",
    "test:sync": "node scripts/sync-conflict-test.mjs",
    "dev": "vite",
    "dev:legacy": "http-server . -p 3000 -g",
    "build": "vite build --config vite.config.cjs && node scripts/copy-static.cjs && node scripts/bundle-app.cjs && node scripts/harden-csp.cjs",
    "build:analyze": "vite build --config vite.config.cjs --mode analyze",
    "preview": "vite preview",
    "backend": "node backend/server.js",
    "backend:dev": "node --watch backend/server.js",
    "start": "vite preview",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "node backend/prisma/seed.js",
    "db:reset": "prisma migrate reset",
    "worker": "node backend/workers/index.js",
    "worker:dev": "node --watch backend/workers/index.js",
    "billing:seed": "node backend/prisma/seed-plans.js",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "vendor:sync": "node scripts/sync-vendor.cjs",
    "postinstall": "node scripts/sync-vendor.cjs",
    "icons:generate": "node scripts/generate-icons.cjs",
    "play-assets:generate": "node scripts/generate-play-assets.cjs",
    "screenshots:capture": "node scripts/capture-screenshots.cjs",
    "test:e2e": "playwright test --config playwright.config.cjs",
    "test:a11y": "playwright test --config playwright.config.cjs accessibility.spec.cjs",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:run": "npx cap run android",
    "android:release": "npm run android:sync && node scripts/android-release.cjs",
    "android:bundle": "npm run android:sync && node scripts/android-bundle.cjs",
    "ios:sync": "npm run build && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:add": "npx cap add ios"
  },
  "keywords": [
    "finanças",
    "pessoais",
    "saas",
    "pwa",
    "javascript"
  ],
  "author": "Renato José Soares",
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.13.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "lucide": "^1.14.0",
    "nodemailer": "^9.0.3",
    "otplib": "^12.0.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "qrcode": "^1.5.4",
    "stripe": "^16.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@capacitor/cli": "^8.4.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.10.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.56.0",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.49.1",
    "prisma": "^5.22.0",
    "sharp": "^0.33.5",
    "supertest": "^7.2.2",
    "terser": "^5.24.0",
    "vite": "^6.4.3"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFiles": [
      "<rootDir>/tests/setup-globals.js"
    ],
    "coverageProvider": "v8",
    "transform": {},
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "js/core/utils.js",
      "js/core/validations.js",
      "js/score.js",
      "js/parser.js",
      "js/core/store.js",
      "js/orcamento.js",
      "js/transacoes.js",
      "js/pipeline.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 40,
        "functions": 25,
        "branches": 30
      }
    },
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "verbose": true
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
